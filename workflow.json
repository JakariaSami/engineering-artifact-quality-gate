      "name": "AI Quality Analysis"
    },
    {
      "parameters": {
        "jsCode": "const aiResponse = $input.first().json;\nconst summary = aiResponse.choices[0].message.content;\nconst prev = $('Merge Results').first().json;\n\nreturn {\n  ...prev,\n  ai_summary: summary\n};"
      },
