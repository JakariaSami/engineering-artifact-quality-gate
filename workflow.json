        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4o-mini\",\n  \"max_tokens\": 300,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a quality engineer reviewing engineering artifacts for release readiness.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Analyze this validation result and give a 2-3 sentence release readiness summary with a clear recommendation.\\n\\nArtifact: {{ $json.artifact_name }}\\nAuthor: {{ $json.author }}\\nNaming Check: {{ $json.check_naming }}\\nFields Check: {{ $json.check_fields }}\\nCompleteness Check: {{ $json.check_completeness }}\\nOverall Status: {{ $json.overall_status }}\"\n    }\n  ]\n}",
        "options": {}
