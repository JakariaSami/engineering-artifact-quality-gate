    {
      "parameters": {
        "jsCode": "const data = $input.first().json.body;\n\nconst namingRegex = /^[A-Z]+_[A-Za-z]+_v\\d+\\.\\d+.*\\.pdf$/;\nconst namingOk = namingRegex.test(data.artifact_name);\n\nconst fieldsOk = [\"author\", \"artifact_name\", \"artifact_type\", \"version\"]\n  .every(f => data[f] && data[f] !== \"\");\n\nconst descriptionOk = data.description && data.description.length > 100;\n\nconst versionOk = parseFloat(data.version) >= 1.0;\n\nconst allPassed = namingOk && fieldsOk && descriptionOk && versionOk;\n\nreturn {\n  ...data,\n  artifact_category: \"SRS\",\n  check_naming: namingOk ? \"PASS\" : \"FAIL - invalid SRS naming format\",\n  check_fields: fieldsOk ? \"PASS\" : \"FAIL - missing required fields\",\n  check_completeness: descriptionOk ? \"PASS\" : \"FAIL - description must be >100 chars for SRS\",\n  check_version: versionOk ? \"PASS\" : \"FAIL - SRS version must be >= 1.0\",\n  overall_status: allPassed ? \"READY\" : \"BLOCKED\",\n  timestamp: new Date().toISOString()\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        64,
        0
      ],
      "id": "c7da73b7-1fdc-401e-93de-019d133e4983",
      "name": "Validate SRS"
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json.body;\n\nconst namingRegex = /^[a-z_]+\\.(yaml|yml)$/;\nconst namingOk = namingRegex.test(data.artifact_name);\n\nconst fieldsOk = [\"author\", \"artifact_name\", \"artifact_type\", \"version\"]\n  .every(f => data[f] && data[f] !== \"\");\n\nconst descriptionOk = data.description && data.description.length > 20;\n\nconst allPassed = namingOk && fieldsOk && descriptionOk;\n\nreturn {\n  ...data,\n  artifact_category: \"YAML\",\n  check_naming: namingOk ? \"PASS\" : \"FAIL - YAML files must be lowercase with .yaml/.yml extension\",\n  check_fields: fieldsOk ? \"PASS\" : \"FAIL - missing required fields\",\n  check_completeness: descriptionOk ? \"PASS\" : \"FAIL - description too short\",\n  check_version: \"N/A\",\n  overall_status: allPassed ? \"READY\" : \"BLOCKED\",\n  timestamp: new Date().toISOString()\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        64,
        176
      ],
      "id": "8f936917-a47e-4421-b489-b03237763a37",
      "name": "Validate YAML Config"
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json.body;\n\nconst namingRegex = /^[A-Za-z0-9_]+\\.[a-z]+$/;\nconst namingOk = namingRegex.test(data.artifact_name);\n\nconst fieldsOk = [\"author\", \"artifact_name\", \"artifact_type\"]\n  .every(f => data[f] && data[f] !== \"\");\n\nconst descriptionOk = data.description && data.description.length > 20;\n\nconst allPassed = namingOk && fieldsOk && descriptionOk;\n\nreturn {\n  ...data,\n  artifact_category: \"Other\",\n  check_naming: namingOk ? \"PASS\" : \"FAIL - invalid file name format\",\n  check_fields: fieldsOk ? \"PASS\" : \"FAIL - missing required fields\",\n  check_completeness: descriptionOk ? \"PASS\" : \"FAIL - description too short\",\n  check_version: \"N/A\",\n  overall_status: allPassed ? \"READY\" : \"BLOCKED\",\n  timestamp: new Date().toISOString()\n};"
      },
